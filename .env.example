# Banco de Dados (PostgreSQL)
# Exemplo para rodar com o Docker: postgresql://admin:adminpassword@postgres:5432/soil_db?schema=public
# Exemplo para rodar localmente: postgresql://admin:adminpassword@localhost:5432/soil_db?schema=public
DATABASE_URL="postgresql://admin:adminpassword@localhost:5432/soil_db?schema=public"

# Autenticação (JWT)
# Coloque qualquer string aleatória aqui
JWT_SECRET="insira-sua-chave-secreta-aqui"

# Redis (Fila e Cache)
# Use 'localhost' se rodar fora do Docker, ou 'redis' se rodar via docker-compose
REDIS_HOST="localhost"
REDIS_PORT=6379

# Porta da API
PORT=3001